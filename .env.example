# LawAgent 环境变量模板
# 复制此文件为 .env 并填入实际值

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DashScope (阿里云 embedding / rerank)
DASHSCOPE_API_KEY=sk-your-dashscope-key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services
RERANK_ENDPOINT=/rerank/text-rerank/text-rerank
RERANK_MODEL=qwen3-rerank

# Tavily 联网搜索
TAVILY_API_KEY=tvly-your-tavily-key

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=law_agent
POSTGRES_USER=law_agent
POSTGRES_PASSWORD=your-postgres-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# 上下文窗口
MAX_CONTEXT_TOKENS=200000
SUMMARY_TRIGGER_RATIO=0.70
MIN_BATCH_TOKENS=40000

# PaddleOCR Docker 服务
OCR_SERVICE_URL=http://localhost:8001

# 服务
APP_HOST=0.0.0.0
APP_PORT=8000
